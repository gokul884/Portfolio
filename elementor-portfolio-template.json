            "_column_size": 40
          },
          "elements": [
            {
              "id": "spinning_badge",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class='spinning-badge-wrapper'><div class='spinning-text-container'><svg class='spinning-text-svg' viewBox='0 0 100 100'><path id='circlePath' d='M 50, 50 m -35, 0 a 35,35 0 1,1 70,0 a 35,35 0 1,1 -70,0'/><text><textPath href='#circlePath'>• CONTACT ME • CONTACT ME • CONTACT ME</textPath></text></svg><div class='inner-arrow'>↗</div></div></div>"
              }
