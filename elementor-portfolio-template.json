            {
              "id": "hero_portrait",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class='portrait-frame'><div class='portrait-backdrop'></div><img src='https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?auto=format&fit=crop&w=700&h=900&q=80' alt='Antor Designer Portrait' class='portrait-img'/><div class='floating-status-pill'><span class='green-pulse'></span><div><p class='status-title'>Current Status</p><p class='status-value'>Available For Hire</p></div></div></div>"
              }
