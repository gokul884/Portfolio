            {
              "id": "testimonials_title",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class='section-header'><div class='antor-badge'>TESTIMONIALS</div><h2>What Our <span class='orange-italic'>Customers</span> Saying</h2><p>Hear directly from our clients about their experiences working with us. Their feedback reflects our commitment to quality, creativity, and results that make a real impact.</p></div>"
              }
            },
            {
              "id": "testimonials_masonry",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class='testimonials-triple-grid'><div class='testimonial-card'><div class='card-meta'><span class='platform-badge linkedin'>in</span><span class='time-ago'>2 mins ago</span></div><p class='testimonial-text'>\"Working with this team was seamless. They understood our vision and delivered exactly what we needed—on time and beyond expectations.\"</p><div class='stars'>★★★★★</div><div class='user-profile'><img src='https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=150&h=150&q=80' alt='Sarah'/><div class='user-info'><h4>Sarah M.</h4><p>Marketing Director at <span class='hl'>Nexus Media</span></p></div></div></div><div class='testimonial-card'><div class='card-meta'><span class='platform-badge linkedin'>in</span><span class='time-ago'>3 days ago</span></div><p class='testimonial-text'>\"Their design work elevated our brand presence. Every detail was thoughtful, and the user experience was smooth and engaging.\"</p><div class='stars'>★★★★★</div><div class='user-profile'><img src='https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=150&h=150&q=80' alt='Jason'/><div class='user-info'><h4>Jason R.</h4><p>Marketing Director at <span class='hl'>Apex Growth</span></p></div></div></div><div class='testimonial-card'><div class='card-meta'><span class='platform-badge twitter'>𝕏</span><span class='time-ago'>5 days ago</span></div><p class='testimonial-text'>\"We saw a noticeable improvement in engagement after the new site launched. Their approach was strategic, creative, and highly professional.\"</p><div class='stars'>★★★★★</div><div class='user-profile'><img src='https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=150&h=150&q=80' alt='Fatima'/><div class='user-info'><h4>Fatima A.</h4><p>Business Owner at <span class='hl'>Solstice Boutique</span></p></div></div></div></div>"
              }
            }
          ]
