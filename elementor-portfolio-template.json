          "settings": {
            "_column_size": 100
          },
          "elements": [
            {
              "id": "works_header",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class='works-section-header'><div class='works-flex'><div class='left-content'><div class='antor-badge-dark'>WORKS</div><h2>My Latest <span class='orange-italic'>Works</span></h2><p>Explore a selection of my projects, showcasing diverse designs and creative solutions across digital platforms.</p></div><div class='right-content'><a href='#works' class='btn-primary'>View All Projects →</a></div></div></div>"
              }
            },
            {
              "id": "works_grid",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class='works-showcase-grid'><div class='work-card'><div class='work-img-frame'><img src='https://images.unsplash.com/photo-1531403009284-440f080d1e12?auto=format&fit=crop&w=1200&q=80' alt='Digital Agency Showcase'/><div class='sticker-overlay'><div class='spinning-text-overlay'><svg viewBox='0 0 100 100'><path id='clickPath2' d='M 50, 50 m -30, 0 a 30,30 0 1,1 60,0 a 30,30 0 1,1 -60,0'/><text><textPath href='#clickPath2'>• CLICK HERE • CLICK HERE</textPath></text></svg><div class='inner-arrow-small'>↗</div></div></div><span class='category-tag'>Web Design</span></div><div class='work-details'><p class='sub-cat'>Digital Agency</p><h3>Digital Agency Landing page</h3><p class='work-desc'>We're a design agency creating impactful solutions through strategy and design. Our designs connect, engage, and elevate your brand.</p><a href='#' class='explore-link'>Explore Showcase ↗</a></div></div><div class='work-card'><div class='work-img-frame'><img src='https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&w=1200&q=80' alt='Banking Solution Showcase'/><span class='category-tag'>UI/UX Design</span></div><div class='work-details'><p class='sub-cat'>Fintech App</p><h3>Banking Solution Header</h3><p class='work-desc'>A clean, secure, and user-friendly design that highlights key banking services and makes navigation simple for users.</p><a href='#' class='explore-link'>Explore Showcase ↗</a></div></div></div>"
              }
            }
          ]
        }
